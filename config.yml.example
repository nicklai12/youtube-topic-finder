# ──────────────────────────────────────────────────────────────────────────────
# config.yml.example — 使用說明
#
# 複製此檔為 config.yml，依需求修改後即可生效。
# config.yml 已加入 .gitignore，不會被 commit（保護個人化設定）。
#
# 若刪除 config.yml，程式會自動使用 src/config.py 內的預設值繼續運行。
# ──────────────────────────────────────────────────────────────────────────────

# ── 搜尋主題與關鍵字 ──────────────────────────────────────────────────────────
# 可自由新增主題（key 名稱即為 GitHub Issue 的 label 名稱）
# 每個主題最多建議 3~5 組關鍵字（過多會消耗更多 API 配額）
topics:
  tech:
    label: tech
    keywords:
      - Python tutorial 2025
      - AI programming
      - software engineering
  finance:
    label: finance
    keywords:
      - 投資理財 2025
      - 股票分析
      - ETF 被動投資

# ── 搜尋參數 ──────────────────────────────────────────────────────────────────
search:
  # 只搜尋最近幾天內發布的影片（整數，單位：天）
  published_within_days: 7
  # 每個關鍵字最多取幾筆結果（上限 50，建議 25）
  max_results: 25

# ── 爆款判定條件 ──────────────────────────────────────────────────────────────
viral:
  # 門檻條件 1：發布後 hours 小時內，觀看次數超過 views → 判定為爆款
  threshold_fast:
    hours: 48
    views: 50000

  # 門檻條件 2：發布後 days 天內，觀看次數超過 views → 判定為爆款
  threshold_slow:
    days: 7
    views: 500000

  # 成長條件：上次記錄到現在，觀看數成長率超過此值 → 判定為爆款
  # 1.0 = 100%（觀看數翻倍）；0.5 = 50% 成長
  growth_rate: 1.0

# ── API 配額保護 ──────────────────────────────────────────────────────────────
quota:
  # 每次執行最多消耗的 YouTube API 配額（YouTube 每日免費上限為 10,000）
  max_units_per_run: 3000

# ── 追蹤資料清理 ──────────────────────────────────────────────────────────────
tracking:
  # 超過幾天未更新的影片記錄，從 data/tracking.json 中自動移除
  expiry_days: 14

# ── 自動關閉 Issue ─────────────────────────────────────────────────────────
auto_close:
  # 是否啟用自動關閉（觀看數不再成長時自動 close Issue）
  enabled: true
  # 當成長率低於此值時，計為一次「無成長」（0.05 = 5%）
  growth_below: 0.05
  # 連續幾次檢查「無成長」後自動關閉（預設 3 次 = 18 小時無成長）
  stale_count: 3
# ── AI 分析（Groq Llama）────────────────────────────────────────────────
analyzer:
  # 是否啟用 AI 分析（需在 GitHub Secrets 設定 GROQ_API_KEY）
  # 未設定 GROQ_API_KEY 時會自動跳過分析，Issue 照常建立
  enabled: true
  # 使用的 Groq 模型（Kimi K2 繁中品質最佳，免費 1,000 req/day、300K TPD）
  model: "moonshotai/kimi-k2-instruct-0905"
  # 字幕語言偏好順序（依序嘗試，都沒有則降級為 metadata 分析）
  preferred_langs: ["zh-TW", "zh-Hant", "zh", "en"]
  # 送入 LLM 的字幕最大字元數（超出則截斷，避免超過 Groq 輸入限制）
  max_transcript_chars: 15000